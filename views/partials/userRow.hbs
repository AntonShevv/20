{{#if linkable}}
<div class="contact-card">
    <a href="/Update/{{id}}" class="contact-link">
        <span class="contact-name">{{name}}</span>
        <span class="contact-phone">{{phoneNumber}}</span>
    </a>
</div>
{{else}}
<div class="contact-card disabled">
    <span class="contact-name">{{name}}</span>
    <span class="contact-phone">{{phoneNumber}}</span>
</div>
{{/if}}