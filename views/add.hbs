<h2>Существующие записи (кнопки-строки заблокированы)</h2>

{{#if users.length}}
<div class="contacts-list preview-list">
    {{#each users}}
    <div class="contact-card disabled">
        <span class="contact-name">{{name}}</span>
        <span class="contact-phone">{{phoneNumber}}</span>
    </div>
    {{/each}}
</div>
{{else}}
<p class="no-records">Нет записей</p>
{{/if}}

<h2>Добавление новой записи</h2>

<form action="/Add" method="POST" class="user-form">
    <div class="form-group">
        <label for="name">Фамилия, имя, отчество:</label>
        <input type="text" id="name" name="name" required placeholder="Петров В.В.">
    </div>
    
    <div class="form-group">
        <label for="phoneNumber">Телефон:</label>
        <input type="text" id="phoneNumber" name="phoneNumber" required placeholder="22233344">
    </div>
    
    <div class="form-actions">
        <button type="submit" class="btn btn-add">Добавить</button>
        <a href="/" class="btn btn-cancel">Отказаться</a>
    </div>
</form>