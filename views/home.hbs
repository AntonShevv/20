{{#if users.length}}
<div class="contacts-list">
    {{#each users}}
    <div class="contact-card">
        <a href="/Update/{{id}}" class="contact-link">
            <span class="contact-name">{{name}}</span>
            <span class="contact-phone">{{phoneNumber}}</span>
        </a>
    </div>
    {{/each}}
</div>
{{else}}
<p class="no-records">Нет записей</p>
{{/if}}

<div class="actions">
    <a href="/Add" class="btn btn-add">Добавить</a>
</div>